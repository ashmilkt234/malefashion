<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shop - E-commerce Store</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
      <link rel="stylesheet" href="/css/style.css" type="text/css">
        <link rel="stylesheet" href="/css/bootstrap.min.css" type="text/css">
  <link rel="stylesheet" href="/css/font-awesome.min.css" type="text/css">
  <link rel="stylesheet" href="/css/elegant-icons.css" type="text/css">
  <link rel="stylesheet" href="/css/magnific-popup.css" type="text/css">
  <link rel="stylesheet" href="/css/nice-select.css" type="text/css">
  <link rel="stylesheet" href="/css/owl.carousel.min.css" type="text/css">
  <link rel="stylesheet" href="/css/slicknav.min.css" type="text/css">
  <link rel="stylesheet" href="/css/style.css" type="text/css">
  <link rel="stylesheet" href="/css/header.css" type="text/css">
    <link rel="stylesheet" href="/css/shop.css">
    <link rel="shortcut icon" href="/img/hero/cr.jpg" type="image/png">
</head>
<body>
       
    <%- include("partials/user/header") %>
    
    <!-- Main Container -->
    <div class="navbar-expand-lg ">
        <!-- Shop Header -->
        <div class="shop-header">
            <h1 class="shop-title">Our Products</h1>
            <div class="search-container">
 <form action="/shop" method="get" class="search-form">
    <input type="hidden" name="category" value="<%= selectedCategory || '' %>">
    <input type="hidden" name="sort" value="<%= sort || '' %>">
    <input type="hidden" name="minPrice" value="<%= minPrice || '' %>">
    <input type="hidden" name="maxPrice" value="<%= maxPrice || '' %>">

    <input type="text"
           name="search"
           class="search-input"
           placeholder="Search products..."
           value="<%= search || '' %>">

    <button type="submit" class="search-btn">
        <i class="fas fa-search"></i>
    </button>

    <a href="/shop" class="btn btn-dark clear-btn">Clear</a>
</form>



            </div>
        </div>

        <!-- Shop Content -->
        <div class="shop-content">
            <!-- Sidebar -->
            <aside class="sidebar">
                <!-- Categories Filter -->
                <div class="filter-section">
                    <h3 class="filter-title">
                        <i class="fas fa-th-large"></i> Categories
                    </h3>
                    <ul class="filter-options">
                        <li class="filter-option <%= !selectedCategory ? 'active' : '' %>">
                            <a href="/shop">All Categories</a>
                        </li>

                        <% categories.forEach(cat => { %>
                            <li class="filter-option <%= selectedCategory == cat._id.toString() ? 'active' : '' %>">
                                <a href="/shop?category=<%= cat._id %>">
                                    <%= cat.name %>
                                </a>
                            </li>
                        <% }) %>
                    </ul>
                </div>

                <!-- Price Filter -->
                <div class="filter-section">
                    <h3 class="filter-title">
                        <i class="fas fa-dollar-sign"></i> Price Range
                    </h3>
                    <form method="GET" action="/shop" class="price-filter-form">
                        <input type="number" name="minPrice" placeholder="Min Price" value="<%= minPrice || '' %>" />
                        <span>to</span>
                        <input type="number" name="maxPrice" placeholder="Max Price" value="<%= maxPrice || '' %>" />
                        <button type="submit">Apply Filter</button>

                        <!-- Preserve category/sort if user already selected -->
                        <% if (selectedCategory) { %>
                            <input type="hidden" name="category" value="<%= selectedCategory %>">
                        <% } %>
                        <% if (sort) { %>
                            <input type="hidden" name="sort" value="<%= sort %>">
                        <% } %>
                    </form>
                </div>
            </aside>

            <!-- Products Container -->
            <main class="products-container">
                <!-- Products Header -->
                <div class="products-header">
                    <div class="products-count">
                        Showing <%= products.length %> products
                    </div>
                    <div class="sort-container">
                 <form id="sortForm" method="get" action="/shop">
    <select class="sort-select" name="sort"
        onchange="document.getElementById('sortForm').submit()">

        <option value="">Sort by popularity</option>
        <option value="latest" <%= sort === 'latest' ? 'selected' : '' %>>
            Sort by latest
        </option>
        <option value="lowtohigh" <%= sort === 'lowtohigh' ? 'selected' : '' %>>
            Sort by price: low to high
        </option>
        <option value="hightolow" <%= sort === 'hightolow' ? 'selected' : '' %>>
            Sort by price: high to low
        </option>
    </select>

    <% if (selectedCategory) { %>
        <input type="hidden" name="category" value="<%= selectedCategory %>">
    <% } %>
    <% if (minPrice) { %>
        <input type="hidden" name="minPrice" value="<%= minPrice %>">
    <% } %>
    <% if (maxPrice) { %>
        <input type="hidden" name="maxPrice" value="<%= maxPrice %>">
    <% } %>
    <% if (search) { %>
        <input type="hidden" name="search" value="<%= search %>">
    <% } %>
</form>

                    </div>
                </div>

                <!-- Product Grid -->
                <% if (products.length > 0) { %>
                    <div class="product__filter">
                        <% for (let i=0; i < products.length; i++) { %>
                            <div class="product__item" onclick="window.location.href='/productDetails/<%= products[i]._id %>'">
                                <div class="product__item__pic">
                                  <a href="/productDetails/<%= products[i]._id %>">
                                        <img src="/Uploads/product-images/<%= products[i].productImage[0] %>"
                                             alt="<%= products[i].productName %>"/> 
                                    </a>
                                    <!-- <button class="wishlist-btn"
        onclick="event.stopPropagation(); addToWishlist('<%= products[i]._id %>')">
        <i class="fa fa-heart"></i>
    </button> -->
                                    <span class="label">New</span>
                               
                            </div>
                                <div class="product__item__text">
                                    <h6><%= products[i].productName %></h6>
                                    <div class="rating">
                                        <% let rating = products[i].rating || 4; %>
                                        <% for (let j=0; j < 5; j++) { %>
                                            <% if (j < rating) { %>
                                                <i class="fa fa-star"></i>
                                            <% } else { %>
                                                <i class="fa fa-star-o"></i>
                                            <% } %>
                                        <% } %>
                                    </div>
                              <h5>$<%= products[i].salesPrice %></h5>
 </div>
<div class="product-actions">

    <!-- Add to Cart -->
    <a href="#" class="add-cart"
       onclick="event.stopPropagation(); addToCart('<%= products[i]._id %>')">
        + Add To Cart
    </a>

    <!-- Wishlist Button -->
    <button class="wishlist-btn"
        onclick="event.stopPropagation(); addToWishlist('<%= products[i]._id %>')">
        <i class="fa fa-heart"></i>
    </button>

                                </div>
                            </div>
                        <% } %>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fas fa-box-open"></i>
                        <h3>No products found</h3>
                        <p>Try adjusting your filters or search terms</p>
                    </div>
                <% } %>

                <!-- Pagination -->
                <% if (totalPages > 1) { %>
                    <div class="pagination">
                        <% if (currentPage > 1) { %>
                            <a href="/shop?page=<%= currentPage - 1 %>&category=<%= selectedCategory || '' %>&sort=<%= sort || '' %>&minPrice=<%= minPrice || '' %>&maxPrice=<%= maxPrice || '' %>" class="page-btn">
                                <i class="fas fa-chevron-left"></i> Prev
                            </a>
                        <% } %>

             <% for (let i = 1; i <= totalPages; i++) { -%>
    <a class="page-btn <%= currentPage === i ? 'active' : '' %>"
       href="/shop?page=<%= i -%>
             &category=<%= selectedCategory || '' -%>
             &sort=<%= sort || '' -%>
             &minPrice=<%= minPrice || '' -%>
             &maxPrice=<%= maxPrice || '' -%>
             &search=<%= search || '' %>">
        <%= i %>
    </a>
<% } %>

                    <% if (currentPage > 1) { %>
    <a href="/shop?page=<%= currentPage - 1 %>&category=<%= selectedCategory || '' %>&sort=<%= sort || '' %>&minPrice=<%= minPrice || '' %>&maxPrice=<%= maxPrice || '' %>&search=<%= search || '' %>" class="page-btn">
        <i class="fas fa-chevron-left"></i> Prev
    </a>
<% } %>

<% if (currentPage < totalPages) { %>
    <a href="/shop?page=<%= currentPage + 1 %>&category=<%= selectedCategory || '' %>&sort=<%= sort || '' %>&minPrice=<%= minPrice || '' %>&maxPrice=<%= maxPrice || '' %>&search=<%= search || '' %>" class="page-btn">
        Next <i class="fas fa-chevron-right"></i>
    </a>
<% } %>
                    </div>
                <% } %>
            </main>
        </div>
    </div>

    <script>
       

        // Search functionality
      

        // Smooth scroll to top when changing pages
        if (window.location.search.includes('page=')) {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Add loading state when navigating
        document.querySelectorAll('a[href^="/shop"]').forEach(link => {
            link.addEventListener('click', function() {
                document.querySelector('.products-container').style.opacity = '0.6';
            });
        });


        async function addToCart(productId) {
  const response = await fetch("/add-to-cart", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      productId: productId,
      quantity: 1
    })
  });

  const data = await response.json();

  if (data.success) {
    window.location.href = "/cart";  // 🔥 This opens cart page
  } else {
    alert(data.message);
  }
}


 if(window.location.search.includes('page=')) {
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

document.querySelectorAll('a[href^="/shop"]').forEach(link => {
    link.addEventListener('click', function() {
        document.querySelector('.products-container').style.opacity = '0.6';
    });
});

async function addToCart(productId) {
  try {
    const response = await fetch("/cart/add", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        productId: productId,
        quantity: 1
      })
    });

    const data = await response.json();

    if (data.success) {
      window.location.href = "/cart";
    } else {
      alert(data.message);
    }

  } catch (error) {
    console.log("Error:", error);
  }
}


async function addToWishlist(productId) {
  const response = await fetch("/add-to-wishlist", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ productId })
  });

  const data = await response.json();

  if (data.success) {
    alert("Added to wishlist ❤️");
  } else {
    alert(data.message);
  }
}


// Remove from Wishlist
async function removeFromWishlist(productId) {
  const response = await fetch("/remove-from-wishlist", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ productId })
  });

  const data = await response.json();

  if (data.success) {
    location.reload();
  }
}


// Move to Cart
async function moveToCart(productId) {
  const response = await fetch("/move-to-cart", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ productId })
  });

  const data = await response.json();

  if (data.success) {
    location.reload();
  } else {
    alert(data.message);
  }
}


// Add to Cart (Shop Page)
async function addToCart(productId) {
  const response = await fetch("/add-to-cart", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      productId,
      quantity: 1
    })
  });

  const data = await response.json();

  if (data.success) {
    window.location.href = "/cart";
  } else {
    alert(data.message);
  }
}
    </script>
</body>
</html>