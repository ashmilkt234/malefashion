<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>cart</title>
</head>


  <%- include("partials/user/header") %>

<link rel="stylesheet" href="/css/cart.css">
  <link rel="stylesheet" href="/css/style.css" type="text/css">
<link rel="stylesheet" href="/css/header.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
      <link rel="stylesheet" href="/css/style.css" type="text/css">
        <link rel="stylesheet" href="/css/bootstrap.min.css" type="text/css">
  <link rel="stylesheet" href="/css/font-awesome.min.css" type="text/css">
  <link rel="stylesheet" href="/css/elegant-icons.css" type="text/css">
  <link rel="stylesheet" href="/css/magnific-popup.css" type="text/css">
  <link rel="stylesheet" href="/css/nice-select.css" type="text/css">
  <link rel="stylesheet" href="/css/owl.carousel.min.css" type="text/css">
  <link rel="stylesheet" href="/css/slicknav.min.css" type="text/css">
  <link rel="stylesheet" href="/css/style.css" type="text/css">
  <link rel="stylesheet" href="/css/header.css" type="text/css">
    <link rel="stylesheet" href="/css/shop.css">
    <link rel="shortcut icon" href="/img/hero/cr.jpg" type="image/png">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<body>
<div class="cart-wrapper">
  <div class="cart-left">
    <h2>Shopping Cart</h2>

    <% if (!cart.items.length) { %>
      <p class="empty-cart">Your cart is empty</p>
    <% } else { %>

      <% cart.items.forEach(item => { %>
        <div class="cart-card">

          <div class="cart-image">
            <img src="/uploads/product-images/<%= item.product_id.productImage[0] %>" alt="">
          </div>

          <div class="cart-details">
            <h4><%= item.product_id.productName %></h4>
            <p>Price: ₹<%= item.product_id.salesPrice %></p>
            <% if (item.product_id.stock < 5) { %>
              <small style="color: #ff6b6b;">Only <%= item.product_id.stock %> left in stock</small>
            <% } %>
          </div>

          <div class="cart-quantity">
            <button onclick="updateQty('<%= item.product_id._id %>', 'dec')" 
                    <%= item.quantity <= 1 ? 'disabled' : '' %>>-</button>
            <span id="qty-<%= item.product_id._id %>"><%= item.quantity %></span>
            <button onclick="updateQty('<%= item.product_id._id %>', 'inc')"
                    <%= item.quantity >= Math.min(5, item.product_id.stock) ? 'disabled' : '' %>>+</button>
          </div>

          <!-- ✅ ONLY CHANGE IN HTML: added data-price attribute -->
          <div class="cart-price" id="price-<%= item.product_id._id %>" data-price="<%= item.product_id.salesPrice %>">
            ₹<%= item.product_id.salesPrice * item.quantity %>
          </div>

          <div class="cart-remove">
            <button onclick="removeFromCart('<%= item.product_id._id %>')">✖</button>
          </div>

        </div>
      <% }) %>

      <a href="/shop" class="back-btn">Back to Shop</a>

    <% } %>
  </div>

  <!-- ORDER SUMMARY -->
  <div class="cart-right">
    <h3>Order Summary</h3>

    <div class="summary-row">
      <span>Subtotal</span>
      <span id="subtotal">₹<%= subtotal %></span>
    </div>

    <div class="summary-row">
      <span>Delivery Charge</span>
      <span>₹50</span>
    </div>

    <div class="summary-total">
      <span>Total</span>
      <span id="total">₹<%= subtotal + 50 %></span>
    </div>

    <a href="/checkout" class="checkout-btn">Checkout</a>
  </div>
</div>

<script>
// ✅ ONLY updateQty function is changed — everything else is untouched
async function updateQty(productId, action) {
  try {
    const qtyElement = document.getElementById(`qty-${productId}`);
    const priceElement = document.getElementById(`price-${productId}`);
    const currentQty = parseInt(qtyElement.textContent);

    if (action === 'dec' && currentQty <= 1) {
      const result = await Swal.fire({
        title: "Remove product?",
        text: "Do you want to remove this product from cart?",
        icon: "question",
        showCancelButton: true,
        confirmButtonColor: "#d33",
        cancelButtonColor: "#3085d6",
        confirmButtonText: "Yes, remove it!",
        cancelButtonText: "No"
      });
      if (result.isConfirmed) removeFromCart(productId);
      return;
    }

    const response = await fetch("/cart/update", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ productId, action })
    });

    const data = await response.json();

    if (data.success) {
      // ✅ Update quantity
      const newQty = action === 'inc' ? currentQty + 1 : currentQty - 1;
      qtyElement.textContent = newQty;

      // ✅ Update item price
      const unitPrice = parseInt(priceElement.dataset.price);
      priceElement.textContent = `₹${unitPrice * newQty}`;

      // ✅ Update subtotal and total
      const prices = document.querySelectorAll('.cart-price');
      let subtotal = 0;
      prices.forEach(p => {
        subtotal += parseInt(p.textContent.replace('₹', ''));
      });
      document.getElementById('subtotal').textContent = `₹${subtotal}`;
      document.getElementById('total').textContent = `₹${subtotal + 50}`;

      // ✅ Update button disabled state
      const decBtn = qtyElement.previousElementSibling;
      const incBtn = qtyElement.nextElementSibling;
      decBtn.disabled = newQty <= 1;
      incBtn.disabled = newQty >= 5;

    } else {
      Swal.fire({ icon: 'error', title: 'Cannot update quantity', text: data.message || 'Failed to update quantity' });
    }

  } catch (error) {
    console.error("Update quantity error:", error);
    Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong!' });
  }
}

// ✅ removeFromCart — NO CHANGE
async function removeFromCart(productId) {
  const result = await Swal.fire({
    title: "Are you sure?",
    text: "Do you want to remove this product from cart?",
    icon: "warning",
    showCancelButton: true,
    confirmButtonColor: "#d33",
    cancelButtonColor: "#3085d6",
    confirmButtonText: "Yes, remove it!",
    cancelButtonText: "Cancel"
  });

  if (result.isConfirmed) {
    Swal.fire({
      title: 'Removing...',
      allowOutsideClick: false,
      didOpen: () => {
        Swal.showLoading();
      }
    });

    const res = await fetch("/cart/remove", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ productId })
    });

    const data = await res.json();

    if (data.success) {
      await Swal.fire({
        title: "Removed!",
        text: "Product removed successfully.",
        icon: "success",
        timer: 1500,
        showConfirmButton: false
      });

      location.reload();
    } else {
      Swal.fire("Error", "Failed to remove product", "error");
    }
  }
}

// ✅ checkout button — NO CHANGE
document.addEventListener('DOMContentLoaded', function() {
  const checkoutBtn = document.querySelector('.checkout-btn');
  if (checkoutBtn) {
    checkoutBtn.addEventListener('click', function(e) {
      const subtotal = parseInt(document.getElementById('subtotal').textContent.replace('₹', ''));
      if (subtotal === 0) {
        e.preventDefault();
        Swal.fire({
          icon: 'warning',
          title: 'Empty Cart',
          text: 'Your cart is empty!'
        });
      }
    });
  }
});
</script>

</body>
</html>
<%- include("partials/user/footer") %>