<%- include('../partials/admin/header') %>

<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="/css/orderadmin.css">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
 <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/2.1.2/sweetalert.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/product.css">
<link rel="stylesheet" href="/css/dashboard.css">

<div class="container mt-4">

  <!-- 🔹 Header Row -->
  <div class="d-flex justify-content-between align-items-center mb-3">
    <button class="btn btn-light" onclick="goBack()">← Back</button>

    <h2 class="fw-bold">Orders</h2>

    <div></div>
  </div>

  <!-- 🔹 Search + Filters -->
  <form action="/admin/orders" method="GET" class="d-flex gap-2 mb-3">

    <input 
      type="text" 
      name="search" 
      placeholder="Search Orders..."
      value="<%= search || '' %>"
      class="form-control w-25"
    >

    <select name="status" class="form-select w-auto">
      <option value="">All Status</option>
      <option value="Pending" <%= status==='Pending'?'selected':'' %>>Pending</option>
      <option value="Shipped" <%= status==='Shipped'?'selected':'' %>>Shipped</option>
      <option value="Delivered" <%= status==='Delivered'?'selected':'' %>>Delivered</option>
      <option value="Cancelled" <%= status==='Cancelled'?'selected':'' %>>Cancelled</option>
    </select>

    <select name="sort" class="form-select w-auto">
      <option value="latest" <%= sort==='latest'?'selected':'' %>>Latest</option>
      <option value="oldest" <%= sort==='oldest'?'selected':'' %>>Oldest</option>
    </select>

    <button type="submit" class="btn btn-dark"> Clear
      <i class="fa fa-search"></i>
    </button>

    <a href="/admin/orders" class="btn btn-secondary">Clear</a>

  </form>

  <!-- 🔹 Table -->
  <div class="table-responsive">
    <table class="table table-bordered align-middle text-center">

      <thead class="table-light">
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Address</th>
          <th>Date</th>
          <th>Product</th>
          <th>Qty</th>
          <th>Payment</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>
        <% orders.forEach(order => { %>
        <tr>

          <td><%= order.orderID %></td>

          <td><%= order.userId?.name || 'User' %></td>

          <td>
            <%= order.address?.address_line %>, 
            <%= order.address?.city %>
          </td>

          <td>
            <%= new Date(order.createdAt).toLocaleDateString() %>
          </td>

          <td>
            <%= order.items[0]?.productId?.productName || 'Product' %>
          </td>

          <td>
            <%= order.items.reduce((sum,i)=>sum+i.quantity,0) %>
          </td>

          <td>
            <span class="badge bg-info text-dark">
              <%= order.paymentMethod || 'COD' %>
            </span>
          </td>

          <td>
            <span class="badge 
              <%= order.address?.status === 'Delivered' ? 'bg-success' :
                  order.address?.status === 'Cancelled' ? 'bg-danger' :
                  order.address?.status === 'Shipped' ? 'bg-warning' :
                  'bg-secondary' %>">
              <%= order.address?.status || 'Pending' %>
            </span>
          </td>

          <td class="d-flex justify-content-center gap-2">

            <a href="/admin/orders/edit/<%= order._id %>" 
               class="btn btn-sm btn-warning">
               Edit
            </a>

            <button class="btn btn-sm btn-danger"
              onclick="confirmCancel('/admin/orders/cancel/<%= order._id %>')">
              Cancel
            </button>

          </td>

        </tr>
        <% }) %>
      </tbody>

    </table>
  </div>

  <!-- 🔹 Pagination -->
  <div class="d-flex justify-content-center mt-4">

    <% if (currentPage > 1) { %>
      <a href="?page=<%= currentPage-1 %>" class="btn btn-outline-dark me-2">Prev</a>
    <% } %>

    <% for(let i=1;i<=totalPages;i++){ %>
      <a href="?page=<%= i %>" 
         class="btn <%= currentPage===i ? 'btn-dark' : 'btn-outline-dark' %> me-1">
         <%= i %>
      </a>
    <% } %>

    <% if (currentPage < totalPages) { %>
      <a href="?page=<%= currentPage+1 %>" class="btn btn-outline-dark ms-2">Next</a>
    <% } %>

  </div>

</div>

<script>
function goBack() {
  window.history.back();
}

function confirmCancel(url) {
  Swal.fire({
    title: 'Cancel Order?',
    text: 'This cannot be undone!',
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#e53935',
    cancelButtonColor: '#6c757d',
    confirmButtonText: 'Yes, Cancel'
  }).then((result) => {
    if (result.isConfirmed) {
      window.location.href = url;
    }
  })
}
</script>