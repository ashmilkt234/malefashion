<%- include('../partials/admin/header') %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="/css/addcategory.css">
<link rel="stylesheet" href="/css/dashboard.css">

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
   
    

            <div class="content">
                
  <div class="form-container">
  <button class="back-btn" onclick="goBack()">← Back</button>
    <h2 class="form-title">Add Category</h2>
<form id="addCategoryForm">

  <div class="form-group">
    <label>Category</label>
    <input type="text" id="name" name="name" placeholder="Enter category name" autocomplete="off">
    <small class="error" id="nameError"></small>
  </div>

  <div class="form-group">
    <label>Description</label>
    <input type="text" id="description" name="description" placeholder="Enter description">
    <small class="error" id="descError"></small>
  </div>
    const offer = Number(offerInput.value) || 0;

    let valid = true;

    if (name.length < 3) {
        setError(nameInput, 'Minimum 3 characters', 'nameError');
        valid = false;
    }

    if (!description) {
        setError(descInput, 'Description is required', 'descError');
        valid = false;
    }

    if (offer < 0 || offer > 90) {
        setError(offerInput, 'Offer must be 0–90', 'offerError');
        valid = false;
    }

    if (!valid) {
        submitBtn.disabled = false;
        return;
    }

    try {
        const response = await fetch('/admin/addCategory', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, description, categoryOffer: offer })
        });

        const result = await response.json();

        if (response.ok) {
            Swal.fire('Success', result.message, 'success')
                .then(() => window.location.href = '/admin/category');
        } else {
            Swal.fire('Error', result.error || 'Something went wrong', 'error');
        }
    } catch {
        Swal.fire('Error', 'Server error', 'error');
    } finally {
        submitBtn.disabled = false;
    }
});

body: JSON.stringify({
  name,
  description,
  categoryOffer: offer,
  hasSize
})


 function goBack() {
            window.history.back();
        }

</script>


</body>
</html>