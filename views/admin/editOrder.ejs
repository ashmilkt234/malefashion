<%- include('../partials/admin/header') %>



<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
 <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/2.1.2/sweetalert.min.js"></script>
 <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/product.css">
<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="/css/orderadmin.css">


<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #f0f2f5;
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: #1a1a2e;
  }

  .page-wrapper {
    max-width: 900px;
    margin: 32px auto;
    padding: 0 20px;
  }

  /* Header */
  .page-header {
    margin-bottom: 24px;
  }
  .page-header h1 {
    font-size: 24px;
    font-weight: 800;
    color: #1a1a2e;
  }
  .page-header p {
    font-size: 13px;
    color: #888;
    margin-top: 2px;
  }

  /* Back link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: #555;
    text-decoration: none;
    margin-bottom: 20px;
    transition: color 0.2s;
  }
  .back-link:hover { color: #1a1a2e; }

  /* Grid layout */
  .grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 20px;
    align-items: start;
  }

  /* Cards */
  .card {
    background: #fff;
    border-radius: 14px;
    padding: 24px;
    box-shadow: 0 1px 6px rgba(0,0,0,0.06);
  }

  /* Products section */
  .card-title {
    font-size: 15px;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 4px;
  }
  .card-subtitle {
    font-size: 12px;
    color: #aaa;
    margin-bottom: 20px;
  }

  .status-badge {
    display: inline-block;
    padding: 4px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    float: right;
    margin-top: -24px;
  }
  .status-badge.pending        { background: #fff3cd; color: #b8860b; }
  .status-badge.shipped        { background: #cce5ff; color: #0066cc; }
  .status-badge.out-for-delivery { background: #e8d5ff; color: #6600cc; }
  .status-badge.delivered      { background: #d4edda; color: #155724; }
  .status-badge.cancelled      { background: #f8d7da; color: #721c24; }

  /* Product item */
  .product-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid #f5f5f5;
  }
  .product-item:last-of-type { border-bottom: none; }

  .product-icon {
    width: 46px;
    height: 46px;
    background: #f5f5f5;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }

  .product-info { flex: 1; }
  .product-name {
    font-size: 14px;
    font-weight: 600;
    color: #1a1a2e;
  }
  .product-qty {
    font-size: 12px;
    color: #999;
    margin-top: 2px;
  }
  .product-price {
    font-size: 15px;
    font-weight: 700;
    color: #1a1a2e;
  }

  /* Order total */
  .order-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid #f0f0f0;
  }
  .order-total span:first-child {
    font-size: 14px;
    color: #888;
  }
  .order-total span:last-child {
    font-size: 22px;
    font-weight: 800;
    color: #5c35d4;
  }

  /* Update Status section */
  .update-status-card { margin-top: 20px; }
  .update-status-card .card-title { margin-bottom: 16px; }

  .status-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .status-btn {
    padding: 9px 20px;
    border-radius: 8px;
    border: 1.5px solid #e0e0e0;
    background: #fff;
    font-size: 13px;
    font-weight: 600;
    color: #555;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .status-btn:hover {
    border-color: #5c35d4;
    color: #5c35d4;
  }

  .status-btn.active {
    background: #5c35d4;
    border-color: #5c35d4;
    color: #fff;
  }

  /* Hidden submit */
  #statusInput { display: none; }
  .submit-btn {
    margin-top: 20px;
    width: 100%;
    padding: 13px;
    background: #5c35d4;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    font-family: 'Plus Jakarta Sans', sans-serif;
    transition: background 0.2s;
  }
  .submit-btn:hover { background: #4a28b8; }

  /* Customer details card */
  .customer-card .section-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    color: #aaa;
    text-transform: uppercase;
    margin-bottom: 4px;
    margin-top: 16px;
  }
  .customer-card .section-label:first-child { margin-top: 0; }

  .customer-card h3 {
    font-size: 15px;
    font-weight: 700;
    color: #1a1a2e;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .customer-card p {
    font-size: 13.5px;
    color: #444;
    line-height: 1.6;
    font-weight: 500;
  }

  @media (max-width: 700px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>

<div class="page-wrapper">

  <!-- Header -->
  <div class="page-header">
    <h1>Order Details</h1>

  </div>

  <!-- Back -->
        

  <div class="grid">

    <!-- LEFT COLUMN -->
    <div>
          <button class="back-btn" onclick="goBack()">← Back</button> 
      <!-- Products Ordered -->
      <div class="card">

        <div class="card-title">Products Ordered</div>
        <div class="card-subtitle">Items included in <%= order.orderID %></div>

        <!-- Current status badge -->
        <span class="status-badge <%= order.address?.status?.toLowerCase().replace(/\s+/g,'-') || 'pending' %>">
          <%= order.address?.status || 'Pending' %>
        </span>

        <!-- Product items -->
        <% order.items.forEach(item => { %>
        <div class="product-item">
          <div class="product-icon">📦</div>
          <div class="product-info">
            <div class="product-name"><%= item.productId?.productName || 'Product' %></div>
            <div class="product-qty">Qty: <%= item.quantity %> × ₹<%= item.productId?.salesPrice || 0 %></div>
          </div>
          <div class="product-price">₹<%= (item.quantity * (item.productId?.salesPrice || 0)).toLocaleString() %></div>
        </div>
        <% }) %>

        <!-- Order Total -->
        <div class="order-total">
          <span>Order Total</span>
          <span>₹<%= order.items.reduce((sum, i) => sum + (i.quantity * (i.productId?.salesPrice || 0)), 0).toLocaleString() %></span>
        </div>
      </div>

      <!-- Update Status -->
      <div class="card update-status-card">
        <div class="card-title">Update Status</div>

        <form method="POST" action="/admin/orders/edit/<%= order._id %>">
          <input type="hidden" name="status" id="statusInput" value="<%= order.address?.status || 'Pending' %>">

          <div class="status-buttons">
            <% ['Pending','Shipped','Out for Delivery','Delivered','Cancelled'].forEach(s => { %>
              <button 
                type="button" 
                class="status-btn <%= (order.address?.status || 'Pending') === s ? 'active' : '' %>"
                onclick="selectStatus(this, '<%= s %>')">
                <%= s %>
              </button>
            <% }) %>
          </div>

          <button type="submit" class="submit-btn">Update Order Status</button>
        </form>
      </div>

    </div>

    <!-- RIGHT COLUMN — Customer Details -->
    <div class="card customer-card">
      <h3>👤 Customer details</h3>

      <div class="section-label">Name</div>
      <p><%= order.userId?.name || 'N/A' %></p>

    
   <div class="section-label">Email</div>
<p><%= order.address?.email || order.userId?.email || 'N/A' %></p>

      <div class="section-label">Shipping Address</div>
      <p>
        <%= order.address?.address_line || '' %>,
        <%= order.address?.city || '' %>,
        <%= order.address?.state || '' %>
        <%= order.address?.pincode || '' %>
      </p>
    </div>

  </div>
</div>

<script>
function selectStatus(btn, status) {
  // Remove active from all
  document.querySelectorAll('.status-btn').forEach(b => b.classList.remove('active'));
  // Set active on clicked
  btn.classList.add('active');
  // Update hidden input
  document.getElementById('statusInput').value = status;
}



 function goBack() {
            window.history.back();
        }
</script>